{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git add*)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(node *)",
      "Bash(python*)",
      "Bash(pip install*)",
      "Bash(npm install*)",
      "Bash(npm test*)",
      "Bash(npx jest*)",
      "Bash(npx vitest*)",
      "Bash(git pull*)",
      "Bash(git push*)",
      "Bash(git commit*)",
      "Bash(git clone*)",
      "Bash(git remote*)",
      "Bash(git rebase*)",
      "Bash(git checkout*)",
      "Bash(rm -rf /tmp/launchpad-sync)",
      "Bash(diff *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf .)",
      "Bash(*--force*)",
      "Bash(*> /dev/null 2>&1 &*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/security-check.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-compact-save.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}